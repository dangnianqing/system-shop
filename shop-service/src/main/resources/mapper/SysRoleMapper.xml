<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.system.shop.mapper.SysRoleMapper">
    <resultMap id="roleMap" type="com.system.shop.entity.SysRole">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleteFlag" column="delete_flag"/>
    </resultMap>

    <select id="selectById" resultMap="roleMap">
        SELECT * FROM sys_role
        WHERE id = #{id}
        AND delete_flag = 0
    </select>

    <select id="findAll" resultMap="roleMap">
        SELECT * FROM sys_role
        WHERE delete_flag = 0
    </select>

    <insert id="insert" parameterType="com.system.shop.entity.SysRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (
            name, remark, create_time, create_by,
            update_by, update_time, delete_flag
        ) VALUES (
            #{name}, #{remark}, #{createTime}, #{createBy},
            #{updateBy}, #{updateTime}, #{deleteFlag}
        )
    </insert>

    <update id="update" parameterType="com.system.shop.entity.SysRole">
        UPDATE sys_role
        SET name = #{name},
            remark = #{remark},
            update_by = #{updateBy},
            update_time = #{updateTime},
            delete_flag = #{deleteFlag}
        WHERE id = #{id}
    </update>
</mapper> 